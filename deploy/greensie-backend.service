[Unit]
Description=Greensie backend (FastAPI / uvicorn)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=dan
Group=dan
WorkingDirectory=/home/dan/projects/greensie-app/backend
ExecStart=/home/dan/projects/greensie-app/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
